{
  "name": "@contenox/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Contenox desktop app — chains, files, and a live shell in one thread. Runs on your machine, no cloud required.",
  "author": {
    "name": "Contenox",
    "email": "hello@contenox.com"
  },
  "homepage": "https://contenox.com",
  "main": "main.js",
  "scripts": {
    "start": "electron . --dev --no-sandbox",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "36.9.5",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.contenox.app",
    "productName": "Contenox",
    "extraResources": [
      { "from": "../../bin/contenox-runtime", "to": "contenox-runtime" }
    ],
    "artifactName": "contenox-${version}-${arch}.${ext}",
    "linux": { "target": ["AppImage"] }
  }
}
